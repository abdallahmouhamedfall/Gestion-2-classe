<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Absences - EduClass</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="layout">
        <div class="sidebar">
            <div class="logo-row">
                <div class="logo-e">E</div>
                <div class="logo-text">EduClass</div>
            </div>
            
            <div class="section">PRINCIPAL</div>
            <a href="#" class="nav-link">📊 Tableau de bord</a>
            
            <div class="section">ACADÉMIQUE</div>
            <a href="#" class="nav-link">📚 Étudiants <span class="badge-count">42</span></a>
            <a href="#" class="nav-link">👨‍🏫 Enseignants <span class="badge-count green">8</span></a>
            <a href="#" class="nav-link">📅 Séances</a>
            
            <div class="section">GESTION</div>
            <a href="#" class="nav-link">📝 Notes</a>
            <a href="#" class="nav-link">📋 Évaluations</a>
            <a href="#" class="nav-link">📆 Planning</a>
            <a href="#" class="nav-link active">⚠️ Absences <span class="badge-count red">5</span></a>
            <a href="#" class="nav-link">🚪 Déconnexion</a>
        </div>

        <div class="main">
            <div class="top-header">
                <div class="date-user"></div>
                <button class="btn-primary">+ Signaler une absence</button>
            </div>

            <h1 class="page-title">Absences & retards</h1>
            <p class="page-subtitle">Gestion des présences et justificatifs</p>

            <div class="stats-row">
                <div class="stat-box">
                    <div class="stat-num red">5</div>
                    <div class="stat-txt">Absences cette semaine</div>
                </div>
                <div class="stat-box">
                    <div class="stat-num yellow">3</div>
                    <div class="stat-txt">Retards signalés</div>
                </div>
                <div class="stat-box">
                    <div class="stat-num cyan">2</div>
                    <div class="stat-txt">Justificatifs reçus</div>
                </div>
            </div>

            <div class="table-container">
                <div class="search-row">
                    <input class="search-box" placeholder="🔍 Rechercher par étudiant, matière, motif...">
                    <button class="btn-secondary">Filtre ▾</button>
                    <button class="btn-secondary">Export ↓</button>
                </div>

                <table class="absence-table">
                    <tr>
                        <th>ÉTUDIANT</th>
                        <th>DATE</th>
                        <th>MATIÈRE</th>
                        <th>TYPE</th>
                        <th>MOTIF</th>
                        <th>JUSTIFIÉ</th>
                        <th>ACTIONS</th>
                    </tr>
                    <tr>
                        <td><div class="student-cell"><div class="avatar-small" style="background:#fb923c">PC</div>Penda Coly</div></td>
                        <td>07/05/2026</td>
                        <td>Maths</td>
                        <td><span class="tag absence">Absence</span></td>
                        <td>Maladie</td>
                        <td><span class="tag oui">Oui</span></td>
                        <td><div class="action-icons"><span>👁️</span><span>✏️</span><span>🗑️</span></div></td>
                    </tr>
                    <tr>
                        <td><div class="student-cell"><div class="avatar-small" style="background:#22d3ee">YM</div>Yacine Meziane</div></td>
                        <td>07/05/2026</td>
                        <td>Physique</td>
                        <td><span class="tag absence">Absence</span></td>
                        <td>—</td>
                        <td><span class="tag non">Non</span></td>
                        <td><div class="action-icons"><span>👁️</span><span>✏️</span><span>🗑️</span></div></td>
                    </tr>
                    <tr>
                        <td><div class="student-cell"><div class="avatar-small" style="background:#f87171">YN</div>Ndeye Yacine Ndiaye</div></td>
                        <td>06/05/2026</td>
                        <td>Histoire</td>
                        <td><span class="tag retard">Retard</span></td>
                        <td>Transport</td>
                        <td><span class="tag partiel">Partiel</span></td>
                        <td><div class="action-icons"><span>👁️</span><span>✏️</span><span>🗑️</span></div></td>
                    </tr>
                    <tr>
                        <td><div class="student-cell"><div class="avatar-small" style="background:#22d3ee">FG</div>Fatou Gniop</div></td>
                        <td>05/05/2026</td>
                        <td>Anglais</td>
                        <td><span class="tag retard">Retard</span></td>
                        <td>—</td>
                        <td><span class="tag non">Non</span></td>
                        <td><div class="action-icons"><span>👁️</span><span>✏️</span><span>🗑️</span></div></td>
                    </tr>
                    <tr>
                        <td><div class="student-cell"><div class="avatar-small" style="background:#22d3ee">LK</div>Lina Khelil</div></td>
                        <td>04/05/2026</td>
                        <td>Maths</td>
                        <td><span class="tag absence">Absence</span></td>
                        <td>Rendez-vous médical</td>
                        <td><span class="tag oui">Oui</span></td>
                        <td><div class="action-icons"><span>👁️</span><span>✏️</span><span>🗑️</span></div></td>
                    </tr>
                </table>
            </div>
        </div>
    </div>
</body>
</html>
